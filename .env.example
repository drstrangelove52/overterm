# Database
DB_HOST=db
DB_PORT=3306
DB_USER=overterm
DB_PASSWORD=changeme
DB_NAME=overterm

# Security
SECRET_KEY=change-this-to-a-random-64-char-string
ENCRYPTION_KEY=change-this-to-a-32-byte-base64-encoded-key

# JWT
ACCESS_TOKEN_EXPIRE_HOURS=8

# First admin (created on first start if no users exist)
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=changeme
FIRST_ADMIN_EMAIL=admin@example.com

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# HTTPS / TLS
# Leave empty → self-signed certificate (works immediately, browser shows warning)
# Set to your public domain → Let's Encrypt certificate (trusted, needs port 80+443 open)
DOMAIN=
