# Database
DB_HOST=db
DB_PORT=3306
DB_USER=overterm
DB_PASSWORD=changeme
DB_NAME=overterm

# Security
# SECRET_KEY is no longer used for token signing (session cookies replaced
# JWT) — it's kept only as a fallback source for the encryption key below.
# Never rotate it if ENCRYPTION_KEY is empty, or stored credentials become
# unreadable.
SECRET_KEY=change-this-to-a-random-64-char-string
ENCRYPTION_KEY=change-this-to-a-32-byte-base64-encoded-key

# Session cookie lifetime (hours)
ACCESS_TOKEN_EXPIRE_HOURS=8
# Leave true — install.sh always deploys behind HTTPS (Caddy). Only set to
# false for local dev outside Docker (uvicorn --reload / npm run dev, both
# plain HTTP), otherwise the browser silently drops the cookie.
SESSION_COOKIE_SECURE=true

# First admin (created on first start if no users exist)
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=changeme
FIRST_ADMIN_EMAIL=admin@example.com

# CORS (comma-separated origins) — only relevant for local dev with the
# frontend and backend on different ports; the deployed app is same-origin
# behind Caddy and doesn't need this.
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# LAN-IP der VM — wird von install.sh automatisch erkannt und gesetzt
LAN_IP=
